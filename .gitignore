node_modules/
.next/
.vercel/
frontend/.next/
frontend/node_modules/
frontend/out/

# --- Docker ---
.docker/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Logs ---
*.log
logs/

