# WARNING: DO NOT put real keys in this file. Copy to .env and edit there.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET=arq-rag-models

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

